<section class="section">
  <div class="container invoice-wrapper">
    <div class="invoice-header">
      <div>
        <h1>Invoice</h1>
        <p class="muted">Invoice date: {{ 'now' | date: '%B %d, %Y' }}</p>
      </div>
      <div>
        <strong>{{ shop.name }}</strong>
        <p class="muted">{{ shop.address }}</p>
      </div>
    </div>

    <table class="invoice-table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Quantity</th>
          <th>Price</th>
        </tr>
      </thead>
      <tbody>
        {% for item in cart.items %}
          <tr>
            <td>{{ item.product.title }}</td>
            <td>{{ item.quantity }}</td>
            <td>{{ item.final_line_price | money }}</td>
          </tr>
        {% else %}
          <tr>
            <td colspan="3">Your cart is empty. Add items to preview the invoice.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    <div class="invoice-summary">
      <p><strong>Subtotal:</strong> {{ cart.items_subtotal_price | money }}</p>
      <p><strong>Taxes:</strong> {{ cart.total_tax | money }}</p>
      <p><strong>Total:</strong> {{ cart.total_price | money }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Invoice Template",
  "settings": []
}
{% endschema %}
