{% comment %}
  Order confirmation email template example.
  Place this file inside your Shopify email templates configuration.
{% endcomment %}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="font-family: Arial, sans-serif; background: #f9fafb;">
  <tr>
    <td align="center" style="padding: 40px 16px;">
      <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="background: #ffffff; border-radius: 12px; padding: 24px;">
        <tr>
          <td>
            <h1 style="margin: 0 0 16px;">Thanks for your order, {{ customer.first_name | default: 'there' }}!</h1>
            <p style="margin: 0 0 16px;">Order {{ order.name }} is confirmed. We’ll email you when it ships.</p>
            <h3 style="margin: 24px 0 8px;">Order summary</h3>
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
              {% for line in order.line_items %}
                <tr>
                  <td style="padding: 8px 0;">{{ line.quantity }} × {{ line.title }}</td>
                  <td align="right" style="padding: 8px 0;">{{ line.final_line_price | money }}</td>
                </tr>
              {% endfor %}
            </table>
            <p style="margin: 16px 0 0;"><strong>Total:</strong> {{ order.total_price | money }}</p>
            <a href="{{ order.order_status_url }}" style="display: inline-block; margin-top: 24px; background: #2563eb; color: #ffffff; padding: 12px 20px; border-radius: 999px; text-decoration: none;">Track your order</a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
